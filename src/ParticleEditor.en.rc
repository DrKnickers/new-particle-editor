IDR_ACCELERATOR1 ACCELERATORS
BEGIN
    VK_DELETE,      ID_EDIT_CLEARALLPARTICLES, VIRTKEY, CONTROL, NOINVERT
    "N",            ID_FILE_NEW,            VIRTKEY, CONTROL, NOINVERT
    "O",            ID_FILE_OPEN,           VIRTKEY, CONTROL, NOINVERT
    "S",            ID_FILE_SAVE,           VIRTKEY, CONTROL, NOINVERT
    "H",            ID_VIEW_DEBUGHEAT,      VIRTKEY, CONTROL, NOINVERT
    VK_HOME,        ID_VIEW_RESETCAMERA,    VIRTKEY, CONTROL, NOINVERT
    "G",            ID_VIEW_SHOWGROUND,     VIRTKEY, CONTROL, NOINVERT
    VK_F5,          ID_VIEW_RELOAD_TEXTURES, VIRTKEY, NOINVERT
    VK_F6,          ID_VIEW_RELOAD_SHADERS,  VIRTKEY, NOINVERT
    VK_UP,          ID_MOVE_EMITTER_UP,     VIRTKEY, ALT, NOINVERT
    VK_DOWN,        ID_MOVE_EMITTER_DOWN,   VIRTKEY, ALT, NOINVERT
    VK_F7,          ID_EMITTER_SPAWNER,     VIRTKEY, NOINVERT
    VK_SPACE,       ID_SPAWNER_TRIGGER,     VIRTKEY, CONTROL, NOINVERT
    "Z",            ID_EDIT_UNDO,           VIRTKEY, CONTROL, NOINVERT
    "Y",            ID_EDIT_REDO,           VIRTKEY, CONTROL, NOINVERT
    "Z",            ID_EDIT_REDO,           VIRTKEY, CONTROL, SHIFT, NOINVERT
    "B",            ID_VIEW_BLOOM,          VIRTKEY, CONTROL, NOINVERT
    VK_F8,          ID_VIEW_PAUSE_PREVIEW,  VIRTKEY, NOINVERT
    VK_F9,          ID_VIEW_STEP_1_FRAME,   VIRTKEY, NOINVERT
    VK_F10,         ID_VIEW_STEP_10_FRAMES, VIRTKEY, NOINVERT
END


