IDR_NEW_EMITTER_MENU MENU 
BEGIN
    POPUP ""
    BEGIN
        MENUITEM "New &Root Emitter",           ID_NEW_EMITTER_ROOT
        MENUITEM "New Child Emitter (&Lifetime)", ID_NEW_EMITTER_LIFETIME
        MENUITEM "New Child Emitter (on &Death)", ID_NEW_EMITTER_DEATH
    END
END

IDR_MENU1 MENU 
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&New\tCtrl+N",                ID_FILE_NEW
        MENUITEM "&Open\tCtrl+O",               ID_FILE_OPEN
        MENUITEM "&Save\tCtrl+S",               ID_FILE_SAVE
        MENUITEM "Save &as",                    ID_FILE_SAVE_AS
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                       ID_FILE_EXIT
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "&Undo\tCtrl+Z",               ID_EDIT_UNDO
        MENUITEM "&Redo\tCtrl+Y",               ID_EDIT_REDO
        MENUITEM SEPARATOR
        MENUITEM "C&ut\tCtrl+X",                ID_EDIT_CUT
        MENUITEM "&Copy\tCtrl+C",               ID_EDIT_COPY
        MENUITEM "&Paste\tCtrl+V",              ID_EDIT_PASTE
        MENUITEM "&Delete\tDel",                ID_EDIT_DELETE
        MENUITEM SEPARATOR
        MENUITEM "Re&scale Particle System",    ID_EDIT_RESCALE
        MENUITEM SEPARATOR
        MENUITEM "C&lear All Particles\tCtrl+Del", ID_EDIT_CLEARALLPARTICLES
    END
    POPUP "E&mitters"
    BEGIN
        POPUP "&New Emitter"
        BEGIN
            MENUITEM "&Root Emitter",               ID_NEW_EMITTER_ROOT
            MENUITEM "Child Emitter (&Lifetime)",   ID_NEW_EMITTER_LIFETIME
            MENUITEM "Child Emitter (on &Death)",   ID_NEW_EMITTER_DEATH
        END
        MENUITEM "&Rename Emitter\tF2",         ID_EMITTER_RENAME
        MENUITEM "Re&scale Emitter",            ID_EMITTER_RESCALE
        MENUITEM "Toggle Emitter &Visibility",  ID_TOGGLE_EMITTER_VISIBILITY
        MENUITEM SEPARATOR
        MENUITEM "S&how All Emitters",          ID_SHOW_ALL_EMITTERS
        MENUITEM "H&ide All Emitters",          ID_HIDE_ALL_EMITTERS
        MENUITEM SEPARATOR
        MENUITEM "&Spawner...\tF7",             ID_EMITTER_SPAWNER
    END
    POPUP "&View"
    BEGIN
        MENUITEM "Show &Ground\tCtrl+G",        ID_VIEW_SHOWGROUND
        MENUITEM "Debug &Heat\tCtrl+H",         ID_VIEW_DEBUGHEAT
        MENUITEM "&Bloom...\tCtrl+B",           ID_VIEW_BLOOM
        MENUITEM "&Lighting...",                ID_VIEW_LIGHTING
        MENUITEM SEPARATOR
        MENUITEM "&Pause Preview\tF8",          ID_VIEW_PAUSE_PREVIEW
        MENUITEM "Step &1 Frame\tF9",           ID_VIEW_STEP_1_FRAME
        MENUITEM "Step 1&0 Frames\tF10",        ID_VIEW_STEP_10_FRAMES
        MENUITEM SEPARATOR
        MENUITEM "Reset &Camera\tCtrl+Home",    ID_VIEW_RESETCAMERA
        MENUITEM SEPARATOR
        MENUITEM "Reload &Textures\tF5",        ID_VIEW_RELOAD_TEXTURES
        MENUITEM "Reload &Shaders\tF6",         ID_VIEW_RELOAD_SHADERS
        MENUITEM SEPARATOR
        MENUITEM "Reset View &Settings",        ID_VIEW_RESET_VIEW_SETTINGS
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About",                      ID_HELP_ABOUT
    END
END

IDR_EMITTER_CONTEXT_MENU MENU 
BEGIN
    POPUP ""
    BEGIN
        MENUITEM "New &Root Emitter",           ID_NEW_EMITTER_ROOT
        MENUITEM "New Child Emitter (&Lifetime)", ID_NEW_EMITTER_LIFETIME
        MENUITEM "New Child Emitter (on &Death)", ID_NEW_EMITTER_DEATH
        MENUITEM SEPARATOR
        MENUITEM "C&ut",                        ID_EDIT_CUT
        MENUITEM "&Copy",                       ID_EDIT_COPY
        MENUITEM "Du&plicate",                  ID_EMITTER_DUPLICATE
        MENUITEM "Duplicate (increment &index)",         ID_EMITTER_DUPLICATE_INC_INDEX
        MENUITEM "Duplicate (increment index...)",        ID_EMITTER_DUPLICATE_INC_INDEX_N
        MENUITEM "&Paste",                      ID_EDIT_PASTE
        POPUP "Paste &As"
        BEGIN
            MENUITEM "Child Emitter (&Lifetime)",   ID_PASTEAS_LIFETIME
            MENUITEM "Child Emitter (on &Death)",   ID_PASTEAS_DEATH
        END
        MENUITEM SEPARATOR
        MENUITEM "&Rename",                     ID_EMITTER_RENAME
        MENUITEM "Re&scale",                    ID_EMITTER_RESCALE
        MENUITEM SEPARATOR
        MENUITEM "Move &Up\tAlt+Up",            ID_MOVE_EMITTER_UP
        MENUITEM "Move D&own\tAlt+Down",        ID_MOVE_EMITTER_DOWN
        MENUITEM SEPARATOR
        MENUITEM "Toggle &Visibility",          ID_TOGGLE_EMITTER_VISIBILITY
        MENUITEM SEPARATOR
        MENUITEM "Delete",                      ID_EDIT_DELETE
    END
END


