IDR_NEW_EMITTER_MENU MENU 
BEGIN
    POPUP ""
    BEGIN
        MENUITEM "Neuen &Root Emitter",         ID_NEW_EMITTER_ROOT
        MENUITEM "Neuen Child Emitter (&Lifetime)", ID_NEW_EMITTER_LIFETIME
        MENUITEM "Neuen Child Emitter (on &Death)", ID_NEW_EMITTER_DEATH
    END
END

IDR_MENU1 MENU 
BEGIN
    POPUP "&Datei"
    BEGIN
        MENUITEM "&Neu\tStrg+N",                ID_FILE_NEW
        MENUITEM "&Öffnen\tStrg+O",             ID_FILE_OPEN
        MENUITEM "&Speichern\tStrg+S",          ID_FILE_SAVE
        MENUITEM "Speichern &als",              ID_FILE_SAVE_AS
        MENUITEM "&Import Emitters from File...", ID_FILE_IMPORT_EMITTERS
        MENUITEM SEPARATOR
        MENUITEM "&Ende",                       ID_FILE_EXIT
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "&Rückgängig\tStrg+Z",         ID_EDIT_UNDO
        MENUITEM "&Wiederholen\tStrg+Y",        ID_EDIT_REDO
        MENUITEM SEPARATOR
        MENUITEM "&Ausschneiden\tStrg+X",       ID_EDIT_CUT
        MENUITEM "&Kopieren\tStrg+C",           ID_EDIT_COPY
        MENUITEM "E&infügen\tStrg+V",           ID_EDIT_PASTE
        MENUITEM "&Löschen\tEntf",              ID_EDIT_DELETE
        MENUITEM SEPARATOR
        MENUITEM "Ver&ändere Partikelsystem",   ID_EDIT_RESCALE
        MENUITEM SEPARATOR
        MENUITEM "&Lösche alle Partikel\tStrg+Entf", ID_EDIT_CLEARALLPARTICLES
    END
    POPUP "E&mitters"
    BEGIN
        POPUP "&Neuen Emitter"
        BEGIN
            MENUITEM "&Root Emitter",               ID_NEW_EMITTER_ROOT
            MENUITEM "Child Emitter (&Lebensdauer)", ID_NEW_EMITTER_LIFETIME
            MENUITEM "Child Emitter (bei &Beendigung)", ID_NEW_EMITTER_DEATH
        END
        MENUITEM "Emitter &Umbenennen\tF2",     ID_EMITTER_RENAME
        MENUITEM "Ver&ändere Emitter",          ID_EMITTER_RESCALE
        MENUITEM "Emitter &Sichtbarkeit",       ID_TOGGLE_EMITTER_VISIBILITY
        MENUITEM SEPARATOR
        MENUITEM "Alle Emitter &anzeigen",      ID_SHOW_ALL_EMITTERS
        MENUITEM "Alle Emitter &verbergen",     ID_HIDE_ALL_EMITTERS
        MENUITEM SEPARATOR
        MENUITEM "&Spawner...\tF7",             ID_EMITTER_SPAWNER
    END
    POPUP "&Ansicht"
    BEGIN
        MENUITEM "Zeige &Boden\tStrg+G",        ID_VIEW_SHOWGROUND
        MENUITEM "Teste &Hitze\tStrg+H",        ID_VIEW_DEBUGHEAT
        MENUITEM "&Bloom...\tStrg+B",           ID_VIEW_BLOOM
        MENUITEM "&Lighting...",                ID_VIEW_LIGHTING
        MENUITEM SEPARATOR
        MENUITEM "&Pause Vorschau\tF8",         ID_VIEW_PAUSE_PREVIEW
        MENUITEM "Schritt &1 Frame\tF9",        ID_VIEW_STEP_1_FRAME
        MENUITEM "Schritt 1&0 Frames\tF10",     ID_VIEW_STEP_10_FRAMES
        MENUITEM SEPARATOR
        MENUITEM "&Kamera zurücksetzen\tStrg+Pos 1", ID_VIEW_RESETCAMERA
        MENUITEM SEPARATOR
        MENUITEM "&Texturen neu laden\tF5",     ID_VIEW_RELOAD_TEXTURES
        MENUITEM "&Shader neu laden\tF6",       ID_VIEW_RELOAD_SHADERS
        MENUITEM SEPARATOR
        MENUITEM "Ansicht &zurücksetzen",       ID_VIEW_RESET_VIEW_SETTINGS
    END
    POPUP "&Hilfe"
    BEGIN
        MENUITEM "&Über",                       ID_HELP_ABOUT
    END
END

IDR_EMITTER_CONTEXT_MENU MENU 
BEGIN
    POPUP ""
    BEGIN
        MENUITEM "Neu &Root Emitter",           ID_NEW_EMITTER_ROOT
        MENUITEM "Neu Child Emitter (&Lebensdauer)", ID_NEW_EMITTER_LIFETIME
        MENUITEM "Neu Child Emitter (bei &Beendigung)", ID_NEW_EMITTER_DEATH
        MENUITEM SEPARATOR
        MENUITEM "Ausschneiden",                ID_EDIT_CUT
        MENUITEM "&Kopieren",                   ID_EDIT_COPY
        MENUITEM "Du&plizieren",                ID_EMITTER_DUPLICATE
        MENUITEM "Duplicate (increment &index)",         ID_EMITTER_DUPLICATE_INC_INDEX
        MENUITEM "Duplicate (increment index...)",        ID_EMITTER_DUPLICATE_INC_INDEX_N
        MENUITEM "&Einfügen",                   ID_EDIT_PASTE
        POPUP "Einfügen als"
        BEGIN
            MENUITEM "Child Emitter (&Lebensdauer)", ID_PASTEAS_LIFETIME
            MENUITEM "Child Emitter (bei &Beendigung)", ID_PASTEAS_DEATH
        END
        MENUITEM SEPARATOR
        MENUITEM "&Umbenennen",                 ID_EMITTER_RENAME
        MENUITEM "Größenänderung",              ID_EMITTER_RESCALE
        MENUITEM SEPARATOR
        MENUITEM "Nach &oben verschieben\tAlt+Auf",   ID_MOVE_EMITTER_UP
        MENUITEM "Nach &unten verschieben\tAlt+Ab",   ID_MOVE_EMITTER_DOWN
        MENUITEM SEPARATOR
        MENUITEM "Sichtbarkeit einstellen",     ID_TOGGLE_EMITTER_VISIBILITY
        MENUITEM SEPARATOR
        MENUITEM "Löschen",                     ID_EDIT_DELETE
    END
END


